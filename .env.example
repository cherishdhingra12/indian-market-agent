# =============================================================================
# Indian Market News Agent — Environment Variables
# =============================================================================
# Copy to .env and fill in your credentials:
#   cp .env.example .env
# =============================================================================

# --- Gemini API Key (FREE) ---
# Get your free key at: https://aistudio.google.com/apikey
# Gemini 2.0 Flash is free: 60 req/min, 1500 req/day
GEMINI_API_KEY=your_gemini_api_key_here

# --- Telegram Bot Credentials ---
# 1. Create bot via @BotFather on Telegram
# 2. Get chat ID from @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Zerodha Kite Connect (LIVE options/futures OI) ---
# Enables real-time F&O Open-Interest signals. Requires a Zerodha account and the
# PAID Kite Connect app (~Rs 500/mo) for live market data.
#   1. Create an app at https://developers.kite.trade -> get API key + secret.
#   2. Each morning generate a fresh access_token (tokens expire ~6am next day):
#        python3 -c "import zerodha_source as z; z.login_url()"      # open + log in
#        python3 -c "import zerodha_source as z; z.exchange_token('REQUEST_TOKEN')"
#      then paste the printed KITE_ACCESS_TOKEN below.
# Leave blank to disable (bot falls back to NSE scrape, currently silent).
KITE_API_KEY=your_kite_api_key_here
KITE_API_SECRET=your_kite_api_secret_here
KITE_ACCESS_TOKEN=your_daily_access_token_here
